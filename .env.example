# ============================================================
# Frontend (Vite)
# ============================================================

# URL бэкенда. В production — полный адрес (https://api.example.com)
VITE_API_URL=

# ============================================================
# Backend (Hono)
# ============================================================

# Neon PostgreSQL connection string
DATABASE_URL=

# Секрет для подписи JWT-токенов (минимум 32 символа)
JWT_SECRET=

# Порт, на котором слушает сервер (по умолчанию 3000)
PORT=3000

# ---- Email (Resend) ----------------------------------------
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Jezkazgan Connect

# ---- Cloudinary (загрузка медиафайлов) ---------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Web Push (VAPID) --------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ---- AI / Gemini -------------------------------------------
GEMINI_API_KEY=

# Включить генерацию видео через Veo (true/false)
VEO_ENABLED=false

# ---- Kaspi Pay ---------------------------------------------
KASPI_MERCHANT_ID=
